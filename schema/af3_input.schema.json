{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AlphaFold 3 Input",
  "type": "object",
  "required": ["name", "sequences", "modelSeeds", "dialect", "version"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "sequences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "oneOf": [
          {
            "required": ["protein"],
            "properties": {
              "protein": { "$ref": "#/$defs/proteinChain" }
            },
            "additionalProperties": false
          },
          {
            "required": ["dna"],
            "properties": {
              "dna": { "$ref": "#/$defs/dnaChain" }
            },
            "additionalProperties": false
          },
          {
            "required": ["rna"],
            "properties": {
              "rna": { "$ref": "#/$defs/rnaChain" }
            },
            "additionalProperties": false
          },
          {
            "required": ["ligand"],
            "properties": {
              "ligand": { "$ref": "#/$defs/ligandChain" }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "modelSeeds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer" }
    },
    "dialect": {
      "type": "string",
      "const": "alphafold3"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4
    },
    "bondedAtomPairs": {
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [
          { "$ref": "#/$defs/atomRef" },
          { "$ref": "#/$defs/atomRef" }
        ],
        "minItems": 2,
        "maxItems": 2
      }
    },
    "userCCD": {
      "type": "string"
    },
    "userCCDPath": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "chainId": {
      "oneOf": [
        { "type": "string", "minLength": 1, "pattern": "^[A-Z]+$" },
        { "type": "array", "items": { "type": "string", "minLength": 1, "pattern": "^[A-Z]+$" }, "minItems": 1 }
      ]
    },
    "atomRef": {
      "type": "array",
      "prefixItems": [
        { "type": "string" },
        { "type": "integer" },
        { "type": "string" }
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "proteinModification": {
      "type": "object",
      "required": ["ptmType", "ptmPosition"],
      "properties": {
        "ptmType": { "type": "string" },
        "ptmPosition": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "nucleotideModification": {
      "type": "object",
      "required": ["modificationType", "basePosition"],
      "properties": {
        "modificationType": { "type": "string" },
        "basePosition": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "template": {
      "type": "object",
      "required": ["queryIndices", "templateIndices"],
      "properties": {
        "mmcif": { "type": "string" },
        "mmcifPath": { "type": "string" },
        "queryIndices": { "type": "array", "items": { "type": "integer" } },
        "templateIndices": { "type": "array", "items": { "type": "integer" } }
      },
      "additionalProperties": false
    },
    "proteinChain": {
      "type": "object",
      "required": ["id", "sequence"],
      "properties": {
        "id": { "$ref": "#/$defs/chainId" },
        "sequence": { "type": "string", "pattern": "^[A-Za-z]+$" },
        "modifications": {
          "type": "array",
          "items": { "$ref": "#/$defs/proteinModification" }
        },
        "description": { "type": "string" },
        "unpairedMsa": { "type": "string" },
        "unpairedMsaPath": { "type": "string" },
        "pairedMsa": { "type": "string" },
        "pairedMsaPath": { "type": "string" },
        "templates": {
          "type": "array",
          "items": { "$ref": "#/$defs/template" }
        }
      },
      "additionalProperties": false
    },
    "dnaChain": {
      "type": "object",
      "required": ["id", "sequence"],
      "properties": {
        "id": { "$ref": "#/$defs/chainId" },
        "sequence": { "type": "string", "pattern": "^[A-Za-z]+$" },
        "modifications": {
          "type": "array",
          "items": { "$ref": "#/$defs/nucleotideModification" }
        },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "rnaChain": {
      "type": "object",
      "required": ["id", "sequence"],
      "properties": {
        "id": { "$ref": "#/$defs/chainId" },
        "sequence": { "type": "string", "pattern": "^[A-Za-z]+$" },
        "modifications": {
          "type": "array",
          "items": { "$ref": "#/$defs/nucleotideModification" }
        },
        "description": { "type": "string" },
        "unpairedMsa": { "type": "string" },
        "unpairedMsaPath": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ligandChain": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "$ref": "#/$defs/chainId" },
        "ccdCodes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "smiles": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
